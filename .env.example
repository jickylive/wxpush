# API 配置
API_TOKEN=your_api_token_here

# 微信公众号配置
WX_APPID=your_wechat_appid
WX_SECRET=your_wechat_secret
WX_USERID=your_wechat_userid
WX_TEMPLATE_ID=your_template_id

# 基础URL配置
WX_BASE_URL=your_base_url

# 注意：
# 1. 请将此文件复制为 .env 并填入真实的配置信息
# 2. .env 文件包含敏感信息，已被 .gitignore 忽略，不会提交到仓库
# 3. 不要将包含真实密钥的 .env 文件分享给他人或提交到版本控制系统
